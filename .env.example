# Example .env for JobPilot (do NOT store real secrets here)

# ── Required API keys ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Credential encryption (auto-generated on first launch if left empty) ──────
CREDENTIAL_KEY=

# ── App settings ──────────────────────────────────────────────────────────────
JOBPILOT_HOST=127.0.0.1
JOBPILOT_PORT=8000
JOBPILOT_LOG_LEVEL=info
JOBPILOT_DATA_DIR=./data
JOBPILOT_SCRAPER_HEADLESS=true
# Comma-separated list of allowed CORS origins. Set this if you serve the
# frontend on a host other than the local dev defaults (e.g. a reverse proxy
# in front of Docker). Leaving the default works for local-only use.
JOBPILOT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# ── Gemini model settings ────────────────────────────────────────────────────
GOOGLE_MODEL=gemini-3-flash-preview
GOOGLE_MODEL_FALLBACKS=

# ── Feature flags ─────────────────────────────────────────────────────────────
SCRAPLING_ENABLED=true
APPLY_TIER1_ENABLED=true
