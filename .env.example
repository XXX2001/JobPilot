# Example .env for JobPilot (do NOT store real secrets here)

# ── Required API keys ─────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Credential encryption (auto-generated on first launch if left empty) ──────
# WARNING — this key decrypts every SiteCredential, Gmail OAuth token, and
# OAuth state HMAC in jobpilot.db. Losing it means re-entering every site
# credential AND re-running the Gmail OAuth flow; there is NO recovery.
#
# Back the generated value up to a password manager BEFORE editing this file
# again. See docs/architecture.md → "Credentials & encryption" for the full
# rotation/restore procedure.
CREDENTIAL_KEY=

# ── App settings ──────────────────────────────────────────────────────────────
JOBPILOT_HOST=127.0.0.1
JOBPILOT_PORT=8000
JOBPILOT_LOG_LEVEL=info
JOBPILOT_DATA_DIR=./data
JOBPILOT_SCRAPER_HEADLESS=true
# Comma-separated list of allowed CORS origins. Set this if you serve the
# frontend on a host other than the local dev defaults (e.g. a reverse proxy
# in front of Docker). Leaving the default works for local-only use.
JOBPILOT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# ── Gemini model settings ────────────────────────────────────────────────────
GOOGLE_MODEL=gemini-3-flash-preview
GOOGLE_MODEL_FALLBACKS=

# Timeouts (seconds)
TECTONIC_TIMEOUT_SECONDS=60
GEMINI_TIMEOUT_SECONDS=45

# ── Feature flags ─────────────────────────────────────────────────────────────
SCRAPLING_ENABLED=true
APPLY_TIER1_ENABLED=true

# ── Gmail integration ─────────────────────────────────────────────────────────
# Gmail integration — leave empty to disable. Obtain at console.cloud.google.com.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/gmail/oauth/callback
GMAIL_BACKFILL_DAYS=30
GMAIL_POLL_INTERVAL_MINUTES=5
